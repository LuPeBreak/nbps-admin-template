# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nbps_dev?schema=public"

# ─── Better Auth ────────────────────────────────────────
BETTER_AUTH_SECRET="replace-with-a-32-char-random-string-please"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Seed admin ─────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="password-with-at-least-8-chars"

# ─── Email (Nodemailer) ─────────────────────────────────
# Switch implícito: SMTP_HOST preenchido => smtp (envia real). Vazio => console (dev, loga JSON no stdout).
# `secure` is auto-derived by nodemailer: port 465 -> SSL, 587/2525 -> STARTTLS. Do NOT set SMTP_SECURE.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
# Optional. Default: SMTP_USER (when smtp) or no-reply@localhost (console).
EMAIL_FROM=""
EMAIL_FROM_NAME="NBPS Admin Template"

# ─── Misc ────────────────────────────────────────────────
# Skip env validation on build steps etc.
# SKIP_ENV_VALIDATION="true"